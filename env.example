# ============================================================
# Ce projet frontend n'a pas de fichier .env propre — il est
# statique et ne contient AUCUN secret (voir js/config.js, qui
# ne contient que l'URL Supabase et la clé "anon", publiques
# par conception).
#
# Les vraies valeurs sensibles vivent uniquement dans :
#   Supabase Dashboard → Edge Functions → Secrets
# et ne doivent JAMAIS être copiées dans ce repo, même dans un
# fichier .env local.
#
# Ce fichier documente uniquement les NOMS des secrets utilisés
# par les 3 Edge Functions (telegram-auth, admin-api, validate-promo).
# ============================================================

# Fourni automatiquement par Supabase — ne pas définir manuellement
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# À définir manuellement dans Supabase → Edge Functions → Secrets
TELEGRAM_BOT_TOKEN=
